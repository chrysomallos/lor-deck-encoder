  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/plugin-syntax-import-assertions": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
